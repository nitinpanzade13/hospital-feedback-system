# MongoDB Configuration
MONGODB_URL=mongodb+srv://username:password@cluster.mongodb.net/?appName=YourApp
DATABASE_NAME=hospital_feedback

# API Configuration
API_HOST=0.0.0.0
API_PORT=8000

# JWT Configuration
# Generate a secure key: openssl rand -hex 32
SECRET_KEY=your-secret-key-here

# Superadmin Default Credentials
SUPERADMIN_EMAIL=superadmin@hospital.com
SUPERADMIN_PASSWORD=YourSecurePassword@123

# Email Configuration (Gmail SMTP)
# 1. Use your Gmail address (e.g., your-email@gmail.com)
# 2. Generate App Password: https://myaccount.google.com/apppasswords
#    (Select Mail > Windows Computer, get 16-char password)
# 3. Paste the 16-char password as EMAIL_PASSWORD
EMAIL_USER=your-email@gmail.com
EMAIL_PASSWORD=your-16-char-app-password
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587

# Frontend URL (use IP address for network access, localhost for local only)
# Docker: Use your machine's network IP (e.g., http://192.168.x.x:3000)
# Local: Use http://localhost:3000
APP_URL=http://localhost:3000

# Frontend API URL
# Leave empty to use relative URLs with nginx proxy (recommended for Docker)
REACT_APP_API_URL=

# Google Forms Integration
# Replace with your actual Google Form URL
GOOGLE_FORM_URL=https://docs.google.com/forms/d/YOUR_FORM_ID/viewform

# AI Worker
BACKEND_URL=http://localhost:8000
POLLING_INTERVAL=5
BATCH_SIZE=10
